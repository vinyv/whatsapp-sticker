{
    "manifest_version": 3,
    "name": "WppBot YouTube Volume",
    "version": "1.0",
    "description": "Controls YouTube player volume via WebSocket commands from WppBot",
    "permissions": [],
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}