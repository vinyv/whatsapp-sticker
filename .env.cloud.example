# WhatsApp Sticker Bot - Cloud Configuration
# Copy this to .env and fill in your values

# Google Books API
GOOGLE_BOOKS_API_KEY=

# Notion Integration
NOTION_API_KEY=
NOTION_DB_ID=

# Book Club
BOOKCLUB_GROUP_ID=

# Local Worker (your PC, via Cloudflare Tunnel)
LOCAL_WORKER_URL=https://wppbot-worker.your-domain.com
LOCAL_WORKER_SECRET=generate-a-random-secret-here
